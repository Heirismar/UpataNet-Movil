{
  "expo": {
    "name": "Upatanet",
    "slug": "upatanet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/img/icon.png",
    "scheme": "upatanet",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/img/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3EBE1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.upatanet.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/img/favicon.png",
        "backgroundColor": "#F3EBE1"
      },
      "package": "com.upatanet.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/img/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
