{
  "expo": {
    "name": "Upatanet",
    "slug": "upatanet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/img/splash-icon.png",
    "primaryColor": "#F2ECE0",
    "scheme": "upatanet",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/img/splash-icon-title.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2ECE0",
      "dark": {
        "image": "./assets/img/splash-icon-title.png",
        "resizeMode": "contain",
        "backgroundColor": "#F2ECE0"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.upatanet.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/img/splash-icon.png",
        "backgroundColor": "#F2ECE0"
      },
      "splash": {
        "image": "./assets/img/splash-icon-title.png",
        "backgroundColor": "#F2ECE0",
        "dark": {
          "image": "./assets/img/splash-icon-title.png",
          "backgroundColor": "#F2ECE0"
        }
      },
      "package": "com.upatanet.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/img/splash-icon-title.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
